{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@iot/shared": ["../shared/src/index.ts"],
      "@iot/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
